# Cloudflare R2 credentials
# Create an R2 API token at: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 bucket names (defaults shown — change if yours differ)
R2_RADAR_BUCKET=radar-tiles
R2_FORECAST_BUCKET=forecast-tiles

# Public CDN URLs for your R2 buckets
# Set up a custom domain or use the default R2.dev subdomain in the Cloudflare dashboard
R2_RADAR_TILES_URL=https://radar-tiles.yourdomain.com
R2_FORECAST_TILES_URL=https://forecast-tiles.yourdomain.com
